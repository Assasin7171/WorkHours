<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="WorkHours.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:WorkHours.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="WorkHours">

    <TabBar>
        <Tab Title="Home">
            <ShellContent ContentTemplate="{DataTemplate pages:MainPage}"
                          Title="Home Page" />
        </Tab>
        <Tab Title="Statistics">
            <ShellContent ContentTemplate="{DataTemplate pages:StatisticsPage}"
                          Title="Statistics Page"/>
        </Tab>
        <Tab Title="Settings">
            <ShellContent Title="Settings Page"
                          ContentTemplate="{DataTemplate pages:SettingsPage}" />
        </Tab>
    </TabBar>


</Shell>