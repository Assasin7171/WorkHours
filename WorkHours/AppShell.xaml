<?xml version="1.0" encoding="UTF-8"?>

<Shell
    x:Class="WorkHours.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:WorkHours.Views.Pages"
    xmlns:views="clr-namespace:WorkHours.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="WorkHours">

    <ShellContent
        Title="Sign In"
        ContentTemplate="{DataTemplate views:LoginView}"
        Route="loginView" />
    <ShellContent
        Title="Sign Up"
        ContentTemplate="{DataTemplate views:RegisterUserView}"
        Route="registerView" />
    
    <ShellContent
        Title="Edit Locations"
        ContentTemplate="{DataTemplate pages:EditLocationsPage}"
        Route="EditLocationsPage" />
    <ShellContent
        Title="User settings"
        ContentTemplate="{DataTemplate pages:UserSettingsPage}"
        Route="UserSettingsPage" />
    
    <TabBar>
        <ShellContent
            Title="Main"
            ContentTemplate="{DataTemplate views:MainApp}"
            Route="MainApp"/>
        <ShellContent
            Title="DataView"
            ContentTemplate="{DataTemplate views:DataView}"
            Route="DataView"/>
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate views:SettingsView}"
            Route="SettingsView"/>
    </TabBar>

</Shell>